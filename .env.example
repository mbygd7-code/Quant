# ──────────────────────────────────────────────────────────────
# QuantSignal — local environment variables
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored. NEVER commit secrets.
# In CI/CD, the same keys live in:
#   - GitHub Secrets (Actions runners)
#   - Vercel Environment Variables (apps/web + apps/api)
# ──────────────────────────────────────────────────────────────

# ====== Supabase ======
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=eyJh...
SUPABASE_SERVICE_ROLE_KEY=eyJh...     # backend ONLY — never ship to client

# Direct Postgres (for bulk reads / backtest only — see SKILL.md §10-2)
SUPABASE_DB_HOST=db.<project-ref>.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=

# Storage bucket names (private buckets created in Supabase Dashboard)
SUPABASE_BUCKET_RAW=raw-api-backups
SUPABASE_BUCKET_BACKTEST=backtest-reports
SUPABASE_BUCKET_REPORTS=daily-reports

# ====== Web (NEXT_PUBLIC_* are exposed to browser) ======
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJh...

# ====== Cache ======
REDIS_URL=redis://localhost:6379/0    # or Upstash URL

# ====== AI ======
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ====== Data sources ======
FINNHUB_API_KEY=
DART_API_KEY=
ALPHA_VANTAGE_KEY=                    # optional — admin ad-hoc analysis only

# ====== Telegram (Beta) ======
TELEGRAM_BOT_TOKEN=                   # BotFather
TELEGRAM_CHAT_IDS=                    # comma-separated (admin + beta testers)
TELEGRAM_ADMIN_CHAT_ID=               # operator chat_id (failure alerts)
TELEGRAM_WEBHOOK_SECRET=              # 16+ chars random — verifies Telegram→Vercel
TELEGRAM_USE_WEBHOOK=true             # Vercel: true / local polling: false

# ====== Notification (Phase 2) ======
KAKAO_BIZ_API_KEY=
KAKAO_TEMPLATE_ID=

NOTIFY_CHANNELS=telegram              # telegram | kakao | telegram,kakao
DRY_RUN=false

# ====== Execution safety (CLAUDE.md §D) ======
EXECUTION_MODE=report_only            # report_only | paper | kis_real | kiwoom_real

# ====== Schedule ======
PIPELINE_RUN_TIME=06:00               # KST
TIMEZONE=Asia/Seoul

# ====== GitHub (used by apps/api on Vercel to dispatch backtest workflow) ======
GITHUB_REPO=<owner>/Quant
GITHUB_PAT=                           # fine-grained, Quant repo only, Actions:write
