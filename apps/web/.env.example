# Copy to .env.local for local dev. Never commit real values.
# Vercel manages production values via dashboard env vars.

NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJh...

# Server-only — used by Server Components / Route Handlers. NEVER prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=eyJh...

NEXT_PUBLIC_APP_URL=http://localhost:3000

# FastAPI base URL (apps/api on Vercel). Defaults to /api in same origin.
NEXT_PUBLIC_API_BASE_URL=/api
